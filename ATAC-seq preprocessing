### 6.Remove duplicates With Picard + sorting and indexing. Removing PCR duplicates on all filtered ATAC-seq Bam files.
#Bash script 
nano dedup_all.sh

#!/usr/bin/env bash
set -euo pipefail

BASE="/data/240117_A01447.A.Project_Pandey-ATAC1-2024-01-12"
FILTER_DIR="${BASE}/filtered"
DEDUP_DIR="${BASE}/dedup"
TMP_DIR="${BASE}/tmp_picard"
THREADS=6

# Picard jar (from your find output; recommended choice)
PICARD_JAR="/data/miniconda/share/picard-2.20.4-0/picard.jar"

mkdir -p "${DEDUP_DIR}" "${TMP_DIR}"

echo "Using Picard jar: ${PICARD_JAR}"
echo "Using temp dir:   ${TMP_DIR}"
echo

for BAM in "${FILTER_DIR}"/*_filtered.bam; do
  sample_base=$(basename "${BAM%_filtered.bam}")
  UNSORTED="${DEDUP_DIR}/${sample_base}_dd_unsorted.bam"
  SORTED="${DEDUP_DIR}/${sample_base}_dd_sorted.bam"
  METRICS="${DEDUP_DIR}/${sample_base}_dup_metrics.txt"

  echo ">>> MarkDuplicates ${sample_base}"

  # If a previous run crashed, remove partial outputs
  rm -f "${UNSORTED}" "${SORTED}" "${SORTED}.bai" "${METRICS}"

  # Run Picard with temp redirected to /data (NOT /tmp)
  java -Djava.io.tmpdir="${TMP_DIR}" -Xmx8g -jar "${PICARD_JAR}" MarkDuplicates \
    INPUT="${BAM}" \
    OUTPUT="${UNSORTED}" \
    METRICS_FILE="${METRICS}" \
    REMOVE_DUPLICATES=true \
    TMP_DIR="${TMP_DIR}" \
    VALIDATION_STRINGENCY=SILENT

  samtools sort --threads "${THREADS}" -o "${SORTED}" "${UNSORTED}"
  samtools index -@ "${THREADS}" "${SORTED}"
  rm -f "${UNSORTED}"

  echo ">>> Done ${sample_base}"
  echo
done

