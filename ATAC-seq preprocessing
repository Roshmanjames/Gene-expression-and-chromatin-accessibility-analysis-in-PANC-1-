#!/usr/bin/env bash
set -euo pipefail

BASE="/data/240117_A01447.A.Project_Pandey-ATAC1-2024-01-12"
TRIM_DIR="${BASE}/trimmed"
ALIGN_DIR="${BASE}/alignment"
TMP_DIR="/data/tmp_samtools"

mkdir -p "${ALIGN_DIR}" "${TMP_DIR}"

BT2_INDEX="/data/human_genome/GRCh38_index"

BT2_THREADS=6
SORT_THREADS=2
SORT_MEM="2G"

for R1P in "${TRIM_DIR}"/*_R1_paired.fastq.gz; do
  R2P="${R1P/_R1_paired.fastq.gz/_R2_paired.fastq.gz}"
  [[ -f "${R2P}" ]] || { echo "ERROR: Missing R2 for ${R1P}"; exit 1; }

  sample_base=$(basename "${R1P%_R1_paired.fastq.gz}")
  BAM_SORTED="${ALIGN_DIR}/${sample_base}_sorted.bam"
  BAI="${BAM_SORTED}.bai"
  TMP_PREFIX="${TMP_DIR}/${sample_base}"

  if [[ -s "${BAM_SORTED}" && -s "${BAI}" ]]; then
    echo ">>> SKIP (already aligned): ${sample_base}"
    continue
  fi

  echo ">>> Aligning ${sample_base}"

  bowtie2 --threads "${BT2_THREADS}" --very-sensitive --no-discordant -X 2000 \
    -x "${BT2_INDEX}" -1 "${R1P}" -2 "${R2P}" \
  | samtools view -@ "${SORT_THREADS}" -b - \
  | samtools sort -@ "${SORT_THREADS}" -m "${SORT_MEM}" \
      -T "${TMP_PREFIX}" -o "${BAM_SORTED}" -

  samtools index -@ "${SORT_THREADS}" "${BAM_SORTED}"

  echo ">>> Done ${sample_base}"
  echo
done

