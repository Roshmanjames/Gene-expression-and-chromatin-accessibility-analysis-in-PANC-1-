#Run trimmomatic on all 12 samples in a for loop
#!/usr/bin/env bash
set -euo pipefail

BASE="/data/240117_A01447.A.Project_Pandey-ATAC1-2024-01-12"
TRIM_DIR="${BASE}/trimmed"
mkdir -p "${TRIM_DIR}"

TRIM_JAR="${BASE}/Trimmomatic/Trimmomatic-0.39/Trimmomatic-0.39/trimmomatic-0.39.jar"
ADAPTERS="${BASE}/Trimmomatic/Trimmomatic-0.39/Trimmomatic-0.39/adapters/NexteraPE-PE.fa"

# sanity checks
command -v java >/dev/null || { echo "ERROR: Java not found"; exit 1; }
[[ -f "${TRIM_JAR}" ]] || { echo "ERROR: Trimmomatic jar not found"; exit 1; }
[[ -f "${ADAPTERS}" ]] || { echo "ERROR: Adapter file not found"; exit 1; }

for R1 in "${BASE}"/Sample_*/*_R1_001.fastq.gz; do
    R2="${R1/_R1_001.fastq.gz/_R2_001.fastq.gz}"
    [[ -f "${R2}" ]] || { echo "WARNING: missing R2 for ${R1}, skipping"; continue; }

    sample_base=$(basename "${R1%_R1_001.fastq.gz}")
    out_prefix="${TRIM_DIR}/${sample_base}"

    echo ">>> Trimming ${sample_base}"

    java -jar "${TRIM_JAR}" PE -threads 16 -phred33 \
        -trimlog "${out_prefix}.trimlog" \
        "${R1}" "${R2}" \
        "${out_prefix}_R1_paired.fastq.gz"   "${out_prefix}_R1_unpaired.fastq.gz" \
        "${out_prefix}_R2_paired.fastq.gz"   "${out_prefix}_R2_unpaired.fastq.gz" \
        ILLUMINACLIP:"${ADAPTERS}":2:30:10:2:True \
        LEADING:3 TRAILING:3 MINLEN:36

    echo ">>> Done ${sample_base}"
    echo
done

