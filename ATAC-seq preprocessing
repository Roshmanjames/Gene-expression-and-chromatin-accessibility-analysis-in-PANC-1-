    samtools index -@ "${THREADS}" "${OUT}"
    samtools idxstats "${OUT}"  > "${CHR_DIR}/${sample_base}_normChr.idxstats"
    samtools flagstat "${OUT}" > "${CHR_DIR}/${sample_base}_normChr.flagstat"

    echo ">>> Done ${sample_base}"
