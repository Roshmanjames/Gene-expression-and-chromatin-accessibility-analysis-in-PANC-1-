    # Remove the suffix -> gives you e.g. 1-PANC1-DMSO-1_S381_L002.macs2
    sample=${f%_summits.bed}

    # Decide group from the sample name
    if [[ "$sample" == *DMSO* ]]; then
        group="DMSO"
    elif [[ "$sample" == *THZ531-2H* ]]; then
        group="THZ2h"
    elif [[ "$sample" == *THZ531-4H* ]]; then
        group="THZ4h"
    elif [[ "$sample" == *THZ531-6H* ]]; then
        group="THZ6h"
    else
        echo "WARNING: could not assign group for $sample, setting to UNKNOWN" >&2
        group="UNKNOWN"
    fi

    echo -e "${sample}\t${group}" >> "${meta}"
done

echo "Written metadata to ${meta}"
cat "${meta}"

