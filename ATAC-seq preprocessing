### 11. Remove blacklist regions (BEDTools intersect) ##Download blacklist hg-38 bedfile in ENCODE 
#Make bash script
nano rm_blacklist_all.sh

#RUN
#!/usr/bin/env bash
set -euo pipefail

THREADS=6
BASE="/data/240117_A01447.A.Project_Pandey-ATAC1-2024-01-12"
CHR_DIR="${BASE}/normChr"
BL_DIR="${BASE}/rmblacklist"
BLACKLIST="/data/hg38-blacklist/hg38-blacklist.v2.bed"

mkdir -p "${BL_DIR}"

for BAM in "${CHR_DIR}"/*_normChr.bam; do
  sample_base=$(basename "${BAM%_normChr.bam}")
  OUT="${BL_DIR}/${sample_base}_rmblacklisted.bam"

  echo ">>> Removing blacklist regions for ${sample_base}"

  # BEFORE stats
  samtools flagstat "${BAM}" > "${BL_DIR}/${sample_base}_before_blacklist.flagstat"

  # Count reads overlapping blacklist
  removed=$(bedtools intersect -abam "${BAM}" -b "${BLACKLIST}" -u | samtools view -c -)
  echo "${removed}" > "${BL_DIR}/${sample_base}_blacklist_overlaps.count"

  # Filter reads NOT overlapping blacklist
  bedtools intersect -abam "${BAM}" -b "${BLACKLIST}" -v \
    | samtools sort -@ "${THREADS}" -o "${OUT}" -

  # Index 
  samtools index -@ "${THREADS}" "${OUT}"
  samtools flagstat "${OUT}" > "${BL_DIR}/${sample_base}_rmblacklisted.flagstat"

  echo ">>> Done ${sample_base} — blacklist-overlapping reads removed: ${removed}"
  echo
done



