read_de_genes <- function(csv_path, direction="down",
                           padj_cut=CFG$go_padj, lfc_cut=CFG$lfc_cut_nascent, top_n=NULL) {
  if (!file.exists(csv_path)) { warning("Missing: ",csv_path); return(character(0)) }
  df <- read.csv(csv_path, row.names=1, stringsAsFactors=FALSE) %>%
    filter(!is.na(padj), is.finite(padj), !is.na(log2FoldChange), is.finite(log2FoldChange),
           !is.na(SYMBOL), nzchar(SYMBOL), !grepl("^(ENSG|ENST|NM_|XM_|NR_|XR_)",SYMBOL),
           padj < padj_cut)
  df <- switch(direction,
               up   = df %>% filter(log2FoldChange > 0),
               down = df %>% filter(log2FoldChange < 0),
               df)
  if (!is.null(top_n)) df <- df %>% arrange(desc(abs(log2FoldChange))) %>% slice_head(n=top_n)
  else                 df <- df %>% filter(abs(log2FoldChange) >= lfc_cut)
  unique(df$SYMBOL)
}

run_gost <- function(genes, label, od, bg=NULL) {
  if (length(genes)<5 || !HAS_GPROFILER) return(invisible(NULL))
  library(gprofiler2)
  g <- tryCatch(gost(query=genes, organism="hsapiens", sources=CFG$go_sources,
                     correction_method="fdr", user_threshold=.05,
                     evcodes=TRUE, custom_bg=bg),
                error=function(e){ message("gost failed: ",e$message); NULL })
  if (is.null(g)||is.null(g$result)||nrow(g$result)==0){
    message("No GO:BP hits for: ",label); return(invisible(NULL)) }
  res <- g$result
  res[] <- lapply(res, function(col)
    if (is.list(col)) vapply(col,function(x) paste(x,collapse=","),character(1)) else col)
  write.csv(res, file.path(od,paste0(label,"_GO_BP.csv")), row.names=FALSE, quote=FALSE)
  g
}

