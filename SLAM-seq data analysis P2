bw_files <- list.files(ATAC_DIR, pattern="\\.bigwig$|\\.bw$", full.names=TRUE)
bw_meta  <- tibble(path=bw_files) %>%
  mutate(fname=basename(path),
         condition=case_when(str_detect(fname,regex("DMSO",  ignore_case=TRUE))~"DMSO",
                             str_detect(fname,regex("THZ531",ignore_case=TRUE))~"THZ531",TRUE~"unknown"),
         timepoint={ m <- str_match(fname,regex("_(\\d+)H_",ignore_case=TRUE))
                     ifelse(is.na(m[,2]),"shared",paste0(tolower(m[,2]),"h")) },
         rep=str_match(fname,"rep(\\d+)")[,2])

do_atac <- function(tp) {
  beds   <- vapply(GRP_DEFS, function(g)
    { f <- file.path(BED_DIR,sprintf("THZ531_%s_%s.bed",tp,g$name)); ifelse(file.exists(f),f,NA_character_) },
    character(1))
  if (any(is.na(beds))) return(invisible(NULL))
  bw_d  <- bw_meta %>% filter(condition=="DMSO") %>% arrange(rep) %>% pull(path)
  bw_t  <- bw_meta %>% filter(condition=="THZ531", timepoint==tp|timepoint=="shared") %>% arrange(rep) %>% pull(path)
  if (!length(bw_d)||!length(bw_t)) return(invisible(NULL))
  all_bw  <- c(bw_d,bw_t)
  all_lab <- c(paste0("DMSO_rep",seq_along(bw_d)), paste0("THZ531_",tp,"_rep",seq_along(bw_t)))
  mat_f   <- file.path(DT_DIR,sprintf("ATAC_%s_matrix.gz",tp))
  ht_f    <- file.path(DT_DIR,sprintf("ATAC_%s_heatmap.pdf",tp))
  pf_f    <- file.path(DT_DIR,sprintf("ATAC_%s_profile.pdf",tp))
  grp_str <- paste(vapply(GRP_DEFS,function(g) paste0('"',g$label,'"'),character(1)),collapse=" ")
  if (system("which computeMatrix > /dev/null 2>&1")!=0){
    message("  deepTools not found in PATH — skipping ATAC metaplots"); return(invisible(NULL)) }
  system(sprintf("computeMatrix reference-point --referencePoint TSS -b 2000 -a 2000 -S %s -R %s --skipZeros -p 8 -o %s --samplesLabel %s",
    paste(all_bw,collapse=" "), paste(beds,collapse=" "), mat_f, paste(all_lab,collapse=" ")))
  system(sprintf("plotHeatmap -m %s -o %s --colorMap Blues --regionsLabel %s --whatToShow 'heatmap and colorbar' --plotTitle 'ATAC-seq at TSS | THZ531 %s vs DMSO' --heatmapHeight 15 --heatmapWidth 3 --dpi 300",
    mat_f, ht_f, grp_str, tp))
  system(sprintf("plotProfile -m %s -o %s --plotTitle 'ATAC Profile at TSS | THZ531 %s vs DMSO' --regionsLabel %s --perGroup --plotHeight 6 --plotWidth 8 --legendLocation lower-center --plotFileFormat pdf",
    mat_f, pf_f, tp, grp_str))
}
for (tp in c("2h","4h","6h")) do_atac(tp)
