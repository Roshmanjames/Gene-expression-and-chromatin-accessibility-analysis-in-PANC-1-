# =============================================================================
# C. ANNOTATION (GTF → ENST / SYMBOL map)
#
#  PERFORMANCE: The GTF is parsed only on the first run; the result is written
#  to tx_map_cache.rds next to the GTF.  Every subsequent run loads the RDS
#  (~2 s) instead of re-importing the full GTF (~2-5 min).
#
#  On the first run, build_tx_map() passes feature.type = "transcript" and a
#  minimal colnames vector so rtracklayer skips all non-transcript rows and
#  all unused metadata columns while parsing.
# =============================================================================

build_tx_map <- function(gtf_path) {
  gtf <- rtracklayer::import(
    gtf_path,
    feature.type = "transcript",
    colnames     = c("transcript_id", "gene_id", "gene_name")
  )
  df <- unique(data.frame(
    ENST_FULL = as.character(mcols(gtf)$transcript_id),
    ENSG      = as.character(mcols(gtf)$gene_id),
    SYMBOL    = as.character(mcols(gtf)$gene_name),
    stringsAsFactors = FALSE
  ))
  df$ENST_CORE <- sub("\\..*$", "", df$ENST_FULL)
  df
}

TX_MAP_CACHE <- file.path(CFG$wd, "tx_map_cache.rds")

if (file.exists(TX_MAP_CACHE)) {
  message("Loading cached transcript annotation map (tx_map_cache.rds)…")
  TX_MAP <- readRDS(TX_MAP_CACHE)
} else {
  message("Building transcript annotation map from GTF (first run — will be cached)…")
  ptm    <- proc.time()
  TX_MAP <- build_tx_map(CFG$gtf)
  message(sprintf("  GTF import took %.1f s — saving cache for future runs",
                  (proc.time() - ptm)[["elapsed"]]))
  saveRDS(TX_MAP, TX_MAP_CACHE)
}

annotate_rows <- function(res_df) {
  enst_core <- sub("\\..*$", "", str_extract(rownames(res_df), "ENST[0-9]+(\\.[0-9]+)?"))
  idx  <- match(enst_core, TX_MAP$ENST_CORE)
  out  <- as.data.frame(res_df, stringsAsFactors = FALSE)
  out$ENST         <- enst_core
  out$ENSEMBL_GENE <- TX_MAP$ENSG[idx]
  out$SYMBOL       <- TX_MAP$SYMBOL[idx]
  bad <- is.na(out$SYMBOL) | grepl("^(ENSG|ENST|NM_|XM_|NR_|XR_)", out$SYMBOL)
  out$LABEL <- ifelse(bad, NA_character_, out$SYMBOL)
  out
}

