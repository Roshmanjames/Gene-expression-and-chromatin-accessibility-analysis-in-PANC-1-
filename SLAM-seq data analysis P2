build_coldata <- function(ids) {
  tibble(sample_id=ids) %>%
    mutate(condition=case_when(str_starts(sample_id,"THZ531-2h")~"THZ531-2h",
                                str_starts(sample_id,"THZ531-4h")~"THZ531-4h",
                                str_starts(sample_id,"THZ531-6h")~"THZ531-6h",
                                str_starts(sample_id,"DMSO")~"DMSO", TRUE~sample_id),
           replicate=as.integer(str_extract(sample_id,"\\d+$")),
           treatment=case_when(str_starts(sample_id,"DMSO")~"control",
                               str_starts(sample_id,"THZ531")~"THZ531", TRUE~"other")) %>%
    select(sample_id, condition, replicate, treatment)
}

get_coef <- function(dds, treat, ctrl) {
  rn  <- resultsNames(dds)
  pat <- paste0("^condition_", gsub("-","\\.",treat), "_vs_", gsub("-","\\.",ctrl), "$")
  hit <- rn[grepl(pat, rn)]
  if (length(hit)!=1) stop("Coeff not found: ",treat," vs ",ctrl)
  hit
}

get_res_df <- function(dds, treat, ctrl) {
  coef     <- get_coef(dds,treat,ctrl)
  res_wald <- results(dds, contrast=c("condition",treat,ctrl),
                      independentFiltering=FALSE, cooksCutoff=FALSE)
  res_shr  <- lfcShrink(dds, coef=coef, type="apeglm")
  df       <- as.data.frame(res_shr); df$padj <- res_wald$padj; df
}

get_thr <- function(is_nasc) {
  if (is_nasc) list(padj=CFG$padj_cut_nascent, lfc=CFG$lfc_cut_nascent)
  else         list(padj=CFG$padj_cut_steady,  lfc=CFG$lfc_cut_steady)
}

prefilter_tc <- function(cts, ids, min_tot=5, min_s=2) {
  cs <- cts[,ids,drop=FALSE]
  cts[rowSums(cs)>=min_tot & rowSums(cs>=1)>=min_s, ids, drop=FALSE]
}

compute_sf <- function(cts, coldata, regex, ref) {
  keep <- grepl(regex, coldata$condition)
  cd   <- droplevels(coldata[keep,,drop=FALSE]); rownames(cd) <- cd$sample_id
  cs   <- cts[,cd$sample_id,drop=FALSE]
  cd$condition <- relevel(factor(cd$condition), ref=ref)
  dds  <- DESeqDataSetFromMatrix(cs, cd, design=~condition)
  dds  <- estimateSizeFactors(dds)
  sizeFactors(dds)
}

