run_subgrouping <- function(branch_cfg) {
  tag <- branch_cfg$tag;  tps <- branch_cfg$timepoints
  od  <- mkd(OUT6, tag)
  SG  <- c("Most downregulated"="#d73027","Less downregulated"="#fee090","Not downregulated"="grey80")

  for (tp in tps) {
    f <- file.path(CFG$outdir,"nascent",tag,
                   sprintf("nascent_%s_DE_%s-%s_vs_%s_wald.csv",tag,tag,tp,branch_cfg$ref))
    if (!file.exists(f)){ message("Missing: ",f); next }

    de <- read.csv(f, row.names=1, stringsAsFactors=FALSE)
    de <- as.data.frame(lapply(de,function(x) if(is(x,"Rle")) as.vector(x) else x),
                        stringsAsFactors=FALSE)
    de_g <- de %>% filter(!is.na(SYMBOL),nzchar(SYMBOL)) %>%
      mutate(SYMBOL=str_to_upper(SYMBOL)) %>%
      group_by(SYMBOL) %>%
      arrange(padj,desc(abs(log2FoldChange)),.by_group=TRUE) %>% slice(1) %>% ungroup() %>%
      mutate(neglog10p = -log10(pmax(padj,.Machine$double.eps)),
             subgroup  = case_when(
               !is.na(padj)&padj<CFG$padj_most&log2FoldChange<=-CFG$lfc_cut_nascent ~"Most downregulated",
               !is.na(padj)&padj>=CFG$padj_most&padj<CFG$padj_less&log2FoldChange<=-CFG$lfc_cut_nascent ~"Less downregulated",
               TRUE~"Not downregulated"),
             subgroup = factor(subgroup, levels=names(SG)))

    pfx <- file.path(od, paste0(tag,"_",tp))
    ttl <- sprintf("Nascent RNA (gene-level): THZ531-%s vs DMSO", tp)

    cnt_lbl <- de_g %>% mutate(s=as.character(subgroup)) %>% count(s) %>%
      { setNames(paste0(.$s," (n=",.$n,")"),.$s) }

    p <- ggplot(de_g %>% arrange(subgroup=="Not downregulated"),
                aes(x=log2FoldChange, y=neglog10p, color=subgroup, size=subgroup)) +
      geom_point(alpha=.7,na.rm=TRUE) +
      scale_color_manual(values=SG, labels=cnt_lbl, name=NULL) +
      scale_size_manual(values=c("Most downregulated"=1.8,"Less downregulated"=1.4,"Not downregulated"=.6),
                        guide="none") +
      geom_hline(yintercept=c(-log10(CFG$padj_less),-log10(CFG$padj_most)),
                 linetype="dashed",linewidth=.35,color="grey50") +
      geom_vline(xintercept=c(-CFG$lfc_cut_nascent,CFG$lfc_cut_nascent),
                 linetype="dashed",linewidth=.35,color="grey50") +
      scale_x_continuous(limits=c(-10,10),oob=scales::squish) +
      scale_y_continuous(limits=c(0,30),oob=scales::squish) +
      labs(title=ttl, x="log2 Fold Change", y="-log10(Adjusted P-value)") +
      theme_classic(base_size=11) +
      theme(plot.title=element_text(face="bold",size=11), legend.position="right")
    save_fig(p, paste0(pfx,"_subgroup_volcano"), w=CFG$fig_w_full, h=CFG$fig_h_tall)

    ctab <- de_g %>% mutate(s=as.character(subgroup)) %>% count(s) %>%
      mutate(s=factor(s,levels=names(SG)))
    p2 <- ggplot(ctab, aes(x=s,y=n,fill=s)) +
      geom_col(width=.6,show.legend=FALSE) +
      geom_text(aes(label=n),vjust=-.4,size=3.5) +
      scale_fill_manual(values=SG) +
      scale_y_continuous(expand=expansion(mult=c(0,.12))) +
      labs(title=ttl, x=NULL, y="Number of Genes") + THEME_PUB +
      theme(axis.text.x=element_text(angle=20,hjust=1))
    save_fig(p2, paste0(pfx,"_subgroup_counts"), w=CFG$fig_w_half)

    write.csv(de_g, paste0(pfx,"_subgroups_gene_level.csv"), row.names=FALSE, quote=FALSE)
    for (sg in levels(de_g$subgroup)) {
      writeLines(sort(filter(de_g,subgroup==sg)$SYMBOL),
                 paste0(pfx,"_",gsub(" ","_",sg),"_genes.txt"))
    }
    print(count(mutate(de_g,s=as.character(subgroup)),s))
  }
}
