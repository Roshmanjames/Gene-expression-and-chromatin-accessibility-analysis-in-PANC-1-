# ── Fisher OR heatmap ─────────────────────────────────────────────────────────
OUT7F <- mkd(OUT7, "Fisher_OR")

run_fisher_one <- function(df_gene, geneset, padj_cut=.05, lfc_cut=1.0) {
  in_s <- df_gene$SYMBOL %in% geneset
  aff  <- !is.na(df_gene$padj)&df_gene$padj<padj_cut&
          !is.na(df_gene$log2FoldChange)&df_gene$log2FoldChange<=-lfc_cut
  a <- sum(in_s&aff); b <- sum(in_s&!aff); c <- sum(!in_s&aff); d <- sum(!in_s&!aff)
  if (a+b<3) return(NULL)
  ft <- fisher.test(matrix(c(a,b,c,d),nrow=2,byrow=TRUE), alternative="greater")
  tibble(n_set=a+b, n_affected=a, OR=unname(ft$estimate), p_value=ft$p.value)
}

collapse_sym <- function(df) {
  df %>% mutate(r=ifelse(is.na(padj),Inf,padj)) %>%
    group_by(SYMBOL) %>% arrange(r,.by_group=TRUE) %>%
    slice(1) %>% ungroup() %>% select(-r)
}

