make_volcano_geneset <- function(df, gene_set, set_label, color_hex, title_str,
                                  label_top_n=20, label_all=FALSE,
                                  padj_cut=0.05, lfc_cut=1.0) {
  df <- df %>% mutate(INSET=SYMBOL%in%gene_set, nl10p=-log10(padj),
                      SIG=padj<padj_cut&abs(log2FoldChange)>=lfc_cut, SIG_INSET=INSET&SIG)
  mf <- max(df$nl10p[is.finite(df$nl10p)], na.rm=TRUE); df$nl10p[!is.finite(df$nl10p)] <- mf

  lab_df <- if (label_all) {
    df %>% filter(INSET) %>% arrange(desc(nl10p),desc(abs(log2FoldChange))) %>%
      distinct(SYMBOL,.keep_all=TRUE)
  } else {
    df %>% filter(SIG_INSET) %>% arrange(desc(nl10p),desc(abs(log2FoldChange))) %>%
      distinct(SYMBOL,.keep_all=TRUE) %>% slice_head(n=label_top_n)
  }
  xmax <- max(2,ceiling(quantile(abs(df$log2FoldChange),.995,na.rm=TRUE)))
  ymax <- max(10,ceiling(quantile(df$nl10p[is.finite(df$nl10p)],.995,na.rm=TRUE)))+2

  ggplot(df, aes(log2FoldChange, nl10p)) +
    geom_point(data=filter(df,!INSET), color="grey75",size=.4,alpha=.18) +
    geom_point(data=filter(df,INSET&!SIG_INSET), shape=21,fill=color_hex,
               color="black",stroke=.3,size=1.8,alpha=.65) +
    geom_point(data=filter(df,SIG_INSET), shape=21,fill=color_hex,
               color="black",stroke=.7,size=2.6,alpha=.95) +
    geom_vline(xintercept=0, color="grey35",linewidth=.4) +
    geom_vline(xintercept=c(-lfc_cut,lfc_cut), linetype="dashed",color="grey55",linewidth=.35) +
    geom_hline(yintercept=-log10(padj_cut), linetype="dashed",color="grey55",linewidth=.35) +
    geom_text_repel(data=lab_df,aes(label=SYMBOL),size=3.2,color="black",fontface="italic",
                    box.padding=.4,max.overlaps=Inf,seed=42) +
    coord_cartesian(xlim=c(-xmax,xmax),ylim=c(0,ymax)) +
    labs(title=title_str,
         subtitle=sprintf("%s: %d in set | %d significant",set_label,sum(df$INSET),sum(df$SIG_INSET)),
         x="log2 Fold Change (apeglm)", y=expression(-log[10](p[adj]))) +
    theme_classic(base_size=11) +
    theme(plot.title=element_text(face="bold",size=11),
          plot.subtitle=element_text(size=9,color="grey40"),legend.position="none")
}

