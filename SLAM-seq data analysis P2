read_gene_list <- function(xlsx_path) {
  if (!file.exists(xlsx_path)) return(character(0))
  x <- tryCatch(suppressMessages(read_xlsx(xlsx_path,.name_repair="minimal")),
                error=function(e) NULL)
  if (is.null(x)||ncol(x)==0) return(character(0))
  all_g <- character(0)
  for (i in seq_len(min(ncol(x),3))) {
    v <- toupper(str_trim(as.character(x[[i]])))
    all_g <- c(all_g, v[!is.na(v)&nzchar(v)&v!="NA"&!grepl("^[0-9]+$",v)])
  }
  unique(all_g)
}

read_apeglm_csv <- function(path) {
  if (!file.exists(path)) return(NULL)
  tryCatch({
    df <- suppressMessages(read_csv(path, show_col_types=FALSE))
    if ("...1" %in% names(df)) df <- rename(df, rowname=`...1`)
    df %>% mutate(SYMBOL=toupper(as.character(SYMBOL)),
                  log2FoldChange=as.numeric(log2FoldChange), padj=as.numeric(padj)) %>%
      filter(is.finite(log2FoldChange), is.finite(padj), !is.na(SYMBOL), nzchar(SYMBOL))
  }, error=function(e){ warning(e$message); NULL })
}

parse_apeglm_meta <- function(path) {
  m <- str_match(basename(path), "^(.*)_DE_(.+?)_vs_(.+?)_apeglm\\.csv$")
  if (any(is.na(m[1,2:4]))) return(NULL)
  tibble(file=path,
         branch=ifelse(grepl("/nascent/",path,ignore.case=TRUE),"NASCENT","STEADY"),
         tag=m[1,2], treat=m[1,3], ctrl=m[1,4])
}

