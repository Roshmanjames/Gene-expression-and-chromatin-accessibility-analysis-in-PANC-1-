make_sample_id <- function(fname) {
  bn <- tools::file_path_sans_ext(basename(fname))
  bn <- str_replace(bn, "_([246])H_", "_\\1h_")
  bn <- str_replace(bn, "^(THZ531)_([0-9]+h)_(\\d)$", "\\1-\\2_rep\\3")
  bn <- str_replace(bn, "^(DMSO)_(\\d)$", "\\1_rep\\2")
  bn
}
