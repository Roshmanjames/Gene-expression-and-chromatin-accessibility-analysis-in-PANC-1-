message("\n========== Section 10: PANDA GRN ==========\n")

if (!HAS_PANDA) {
  message("pandaR not installed — skipping GRN analysis.")
} else {
  library(pandaR)
  OUT10     <- mkd(CFG$outdir,"10_GRN_PANDA")
  MOTIF_F   <- file.path(OUT10,"data","motif_human.txt")
  PPI_F     <- file.path(OUT10,"data","ppi_human.txt")
  SAMPS_P   <- list(DMSO=paste0("DMSO_rep",1:3),
                    "2h"=paste0("THZ531-2h_rep",1:3),
                    "4h"=paste0("THZ531-4h_rep",1:3),
                    "6h"=paste0("THZ531-6h_rep",1:3))

  conv_sym <- function(mat) {
    mat <- as.matrix(mat)
    ec  <- sub("\\..*$","",str_extract(rownames(mat),"ENST[0-9]+\\.?[0-9]*"))
    idx <- match(ec,TX_MAP$ENST_CORE); sym <- TX_MAP$SYMBOL[idx]
    k   <- !is.na(sym)&nzchar(sym)
    as.data.frame(mat[k,,drop=FALSE]) %>% mutate(SYMBOL=sym[k]) %>%
      group_by(SYMBOL) %>% summarise(across(everything(),mean),.groups="drop") %>%
      column_to_rownames("SYMBOL") %>% as.matrix()
  }
  nasc_sym <- conv_sym(nascent_counts)
  sst_sym  <- conv_sym(steady_counts)

  norm_expr <- function(nas,sst,sids) {
    ns <- nas[,sids,drop=FALSE]; ss <- sst[,sids,drop=FALSE]
    si <- round(ss[rowSums(round(ss))>1,,drop=FALSE])
    storage.mode(si) <- "integer"
    dds_s <- DESeqDataSetFromMatrix(si,data.frame(row.names=sids,c=rep("x",length(sids))),~1)
    dds_s <- estimateSizeFactors(dds_s,type="poscounts"); sf <- sizeFactors(dds_s)
    ns <- ns[rownames(ns)%in%rownames(si),,drop=FALSE]
    nn <- sweep(ns,2,sf[colnames(ns)],"/"); nn <- nn[rowMeans(nn)>=1,,drop=FALSE]
    ni <- round(nn); storage.mode(ni) <- "integer"
    dds_n <- DESeqDataSetFromMatrix(ni,data.frame(row.names=sids,c=rep("x",length(sids))),~1)
    sizeFactors(dds_n) <- sf[colnames(dds_n)]; assay(vst(dds_n,blind=TRUE))
  }

  if (!file.exists(MOTIF_F)||!file.exists(PPI_F)) {
    message("  Motif/PPI files not found — using pandaToyData")
    data(pandaToyData); motif_p <- pandaToyData$motif; ppi_p <- pandaToyData$ppi
  } else {
    motif_p <- read.table(MOTIF_F,header=FALSE,sep="\t",col.names=c("TF","Gene","score"),stringsAsFactors=FALSE)
    ppi_p   <- read.table(PPI_F, header=FALSE,sep="\t",col.names=c("TF1","TF2","score"),stringsAsFactors=FALSE)
  }

  for (tp in names(SAMPS_P)) {
    rds_f <- file.path(OUT10,tp,paste0("panda_",tp,".rds"))
    tp_d  <- mkd(OUT10,tp)
    if (!file.exists(rds_f)) {
      message("  Running PANDA: ",tp)
      em <- norm_expr(nasc_sym,sst_sym,SAMPS_P[[tp]])
      r  <- panda(motif_p,as.data.frame(em),ppi_p,hamming=.001,progress=TRUE)
      saveRDS(r,rds_f)
      net <- r@regNet
      write.csv(data.frame(TF=rep(rownames(net),ncol(net)),
                            Gene=rep(colnames(net),each=nrow(net)),
                            weight=as.vector(net)),
                file.path(tp_d,paste0("edges_",tp,".csv")),row.names=FALSE,quote=FALSE)
    } else { message("  PANDA cached: ",tp) }
  }
  message("PANDA GRN analysis complete.")
}

