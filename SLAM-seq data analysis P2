read_tabular <- function(path) {
  lines <- readLines(path)
  skip  <- sum(str_starts(lines, "#"))
  df    <- read.table(path, header=TRUE, sep="\t", skip=skip,
                      stringsAsFactors=FALSE, comment.char="")
  df %>% select(Name, ReadCount, TcReadCount) %>% distinct(Name, .keep_all=TRUE)
}

