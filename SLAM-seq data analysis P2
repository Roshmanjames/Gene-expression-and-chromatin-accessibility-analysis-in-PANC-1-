make_volcano <- function(res, treat, ctrl, tag, od, is_nasc, N=40) {
  thr <- get_thr(is_nasc)
  df  <- res %>% filter(is.finite(log2FoldChange), is.finite(padj))
  pass <- !is.na(df$padj) & df$padj<thr$padj & abs(df$log2FoldChange)>=thr$lfc & !is.na(df$LABEL)
  sel  <- df[pass,] %>% mutate(d=ifelse(log2FoldChange>0,"up","dn")) %>%
    group_by(d) %>% slice_min(order_by=padj,n=N) %>% pull(LABEL) %>% unique()
  xmax <- max(2, ceiling(quantile(abs(df$log2FoldChange),.995,na.rm=TRUE)))
  v <- EnhancedVolcano(df, lab=ifelse(pass,df$LABEL,""), x="log2FoldChange", y="padj",
         pCutoff=thr$padj, FCcutoff=thr$lfc, selectLab=sel, max.overlaps=400,
         labSize=2.2, pointSize=1.2, title=sprintf("%s vs %s",treat,ctrl),
         subtitle=sprintf("%s | apeglm LFC | top %d labelled",tag,N), ylim=c(0,80)) +
    scale_x_continuous(limits=c(-xmax,xmax)) +
    scale_y_continuous(breaks=c(0,20,40,60,80),limits=c(0,80))
  save_fig(v, file.path(od,sprintf("%s_volcano_%s_vs_%s",tag,treat,ctrl)),
           w=CFG$fig_w_full, h=CFG$fig_h_tall)
}

make_ma <- function(dds, treat, ctrl, tag, od, is_nasc) {
  thr     <- get_thr(is_nasc)
  coef    <- get_coef(dds,treat,ctrl)
  rw      <- results(dds,contrast=c("condition",treat,ctrl),independentFiltering=FALSE,cooksCutoff=FALSE)
  shr     <- lfcShrink(dds,coef=coef,type="apeglm"); shr$padj <- rw$padj
  up_n    <- sum(!is.na(shr$padj)&shr$padj<thr$padj&shr$log2FoldChange>thr$lfc,  na.rm=TRUE)
  dn_n    <- sum(!is.na(shr$padj)&shr$padj<thr$padj&shr$log2FoldChange<(-thr$lfc),na.rm=TRUE)
  ttl     <- sprintf("%s: %s vs %s\nUp: %d | Down: %d",tag,treat,ctrl,up_n,dn_n)
  base    <- file.path(od,sprintf("%s_MA_%s_vs_%s",tag,treat,ctrl))
  wi <- round(CFG$fig_w_full/2.54*CFG$fig_dpi); hi <- round(CFG$fig_h_std/2.54*CFG$fig_dpi)
  png( paste0(base,".png"),  width=wi, height=hi, res=CFG$fig_dpi)
  DESeq2::plotMA(shr,ylim=c(-10,10),main=ttl)
  abline(h=c(-thr$lfc,thr$lfc),lty=2,col="grey50"); dev.off()
  tiff(paste0(base,".tiff"), width=wi, height=hi, res=CFG$fig_dpi, compression="lzw")
  DESeq2::plotMA(shr,ylim=c(-10,10),main=ttl)
  abline(h=c(-thr$lfc,thr$lfc),lty=2,col="grey50"); dev.off()
}

write_de_tables <- function(dds, treat, ctrl, tag, od) {
  coef <- get_coef(dds,treat,ctrl)
  rw   <- results(dds,contrast=c("condition",treat,ctrl),independentFiltering=FALSE,cooksCutoff=FALSE) %>%
    as.data.frame() %>% annotate_rows() %>% arrange(padj,desc(abs(log2FoldChange)))
  shr       <- lfcShrink(dds,coef=coef,type="apeglm") %>% as.data.frame()
  shr$padj  <- results(dds,contrast=c("condition",treat,ctrl),independentFiltering=FALSE)$padj
  shr       <- shr %>% annotate_rows() %>% arrange(padj,desc(abs(log2FoldChange)))
  base <- file.path(od,sprintf("%s_DE_%s_vs_%s",tag,treat,ctrl))
  write.csv(rw,  paste0(base,"_wald.csv"),   row.names=TRUE, quote=FALSE)
  write.csv(shr, paste0(base,"_apeglm.csv"), row.names=TRUE, quote=FALSE)
}

run_branch <- function(cts, coldata, br, is_nasc=FALSE, ext_sf=NULL) {
  tag <- br$tag; layer <- ifelse(is_nasc,"nascent","steady")
  od  <- mkd(CFG$outdir, layer, tag)
  keep    <- grepl(br$regex, coldata$condition)
  cd      <- droplevels(coldata[keep,,drop=FALSE]); rownames(cd) <- cd$sample_id
  ids     <- cd$sample_id
  ct      <- cts[,ids,drop=FALSE]
  if (is_nasc) ct <- prefilter_tc(ct, ids)
  cd$condition <- relevel(factor(cd$condition), ref=br$ref)
  dds <- DESeqDataSetFromMatrix(ct, cd, design=~condition)
  dds <- dds[rowSums(counts(dds))>1,]
  if (!is.null(ext_sf)) sizeFactors(dds) <- ext_sf[colnames(dds)]
  else dds <- estimateSizeFactors(dds, type="poscounts")
  dds <- DESeq(dds)
  if (is_nasc && tag=="THZ531") saveRDS(dds, file.path(CFG$wd,"dds_thz_nascent.rds"))
  write.csv(counts(dds,normalized=TRUE),
            file.path(od,paste0(tag,"_",layer,"_counts_normalized.csv")), quote=FALSE)
  make_qc_deseq(dds, paste(layer,tag,sep="_"), od)
  for (pr in br$pairs) {
    res <- get_res_df(dds,pr[1],pr[2]) %>% annotate_rows()
    make_volcano(res, pr[1],pr[2], paste(layer,tag,sep="_"), od, is_nasc)
    make_ma(dds, pr[1],pr[2], paste(layer,tag,sep="_"), od, is_nasc)
    write_de_tables(dds, pr[1],pr[2], paste(layer,tag,sep="_"), od)
  }
  invisible(dds)
}

