message("\n========== Section 8: TF Target Analysis ==========\n")

if (!HAS_DECOUPLER) {
  message("decoupleR not installed — skipping.")
} else {
  library(decoupleR)
  OUT8 <- mkd(CFG$outdir,"08_TF_Targets")
  TFS  <- c("FOXA2","SOX9","SOX17","PDX1","HNF1B","HNF6")
  TF_COL <- c(FOXA2="#E74C3C",SOX9="#3498DB",SOX17="#2ECC71",PDX1="#F39C12",
               HNF1B="#9B59B6",HNF6="#1ABC9C")
  RDS <- "/data/SLAM/dorothea_AB_regulon.rds"

  if (file.exists(RDS)) {
    regulon <- readRDS(RDS)
  } else {
    tmp <- tempfile(fileext=".rda")
    download.file("https://raw.githubusercontent.com/saezlab/dorothea/master/data/dorothea_hs.rda",
                  tmp,quiet=FALSE)
    e <- new.env(); load(tmp,envir=e)
    regulon <- e$dorothea_hs %>%
      filter(confidence %in% c("A","B")) %>%
      mutate(source=toupper(tf),target=toupper(target),mor=as.numeric(mor)) %>%
      select(source,target,mor,confidence)
    saveRDS(regulon,RDS)
  }
  if (!"source" %in% names(regulon) && "tf" %in% names(regulon))
    regulon <- rename(regulon, source=tf)

  tf_reg <- regulon %>% filter(source %in% TFS) %>%
    mutate(source=toupper(source),target=toupper(target))

  tfl_dir <- mkd(OUT8,"target_lists")
  for (tf in TFS) {
    tfd <- tf_reg %>% filter(source==tf); if (nrow(tfd)==0) next
    writeLines(sort(unique(tfd$target)), file.path(tfl_dir,paste0(tf,"_targets.txt")))
    write_csv(arrange(tfd,desc(abs(mor))), file.path(tfl_dir,paste0(tf,"_targets_mor.csv")))
  }

  for (tf in TFS) {
    tfd <- tf_reg %>% filter(source==tf); if (nrow(tfd)==0) next
    tf_dir <- mkd(OUT8,tf)
    for (i in seq_len(nrow(fisher_meta))) {
      m  <- fisher_meta[i,]
      df <- read_apeglm_csv(m$file)
      if (is.null(df)||sum(tfd$target %in% df$SYMBOL)==0) next
      df2 <- df %>%
        left_join(tfd %>% select(target,mor) %>% distinct(target,.keep_all=TRUE),
                  by=c("SYMBOL"="target")) %>%
        mutate(INSET=!is.na(mor),is_act=!is.na(mor)&mor>0,is_rep=!is.na(mor)&mor<0,
               nl10p=-log10(padj), SIG=padj<.05&abs(log2FoldChange)>=1, SIG_INSET=INSET&SIG)
      mf <- max(df2$nl10p[is.finite(df2$nl10p)],na.rm=TRUE)
      df2$nl10p[!is.finite(df2$nl10p)] <- mf
      lab <- df2 %>% filter(SIG_INSET) %>%
        arrange(desc(abs(mor)),desc(nl10p)) %>% distinct(SYMBOL,.keep_all=TRUE) %>% slice_head(n=25)
      tp  <- str_match(m$treat,"THZ531-(\\d+h)")[,2]
      ttl <- sprintf("%s Targets — %s vs %s | %s", tf, m$ctrl,
                     ifelse(!is.na(tp),toupper(tp),m$treat), m$branch)
      xmax <- max(2,ceiling(quantile(abs(df2$log2FoldChange),.995,na.rm=TRUE)))
      ymax <- max(10,ceiling(quantile(df2$nl10p[is.finite(df2$nl10p)],.995,na.rm=TRUE)))+2
      p <- ggplot(df2,aes(log2FoldChange,nl10p)) +
        geom_point(data=filter(df2,!INSET),color="grey75",size=.4,alpha=.18) +
        geom_point(data=filter(df2,is_act&!SIG),shape=21,fill=alpha(TF_COL[tf],.45),
                   color="grey50",stroke=.25,size=1.6,alpha=.6) +
        geom_point(data=filter(df2,is_rep&!SIG),shape=25,fill=alpha(TF_COL[tf],.45),
                   color="grey50",stroke=.25,size=1.6,alpha=.6) +
        geom_point(data=filter(df2,is_act&SIG),shape=21,fill=TF_COL[tf],
                   color="black",stroke=.7,size=2.6,alpha=.95) +
        geom_point(data=filter(df2,is_rep&SIG),shape=25,fill=TF_COL[tf],
                   color="black",stroke=.6,size=2.4,alpha=.9) +
        geom_vline(xintercept=c(-1,0,1),linetype=c("dashed","solid","dashed"),
                   color=c("grey55","grey35","grey55"),linewidth=.35) +
        geom_hline(yintercept=-log10(.05),linetype="dashed",color="grey55",linewidth=.35) +
        geom_text_repel(data=lab,aes(label=SYMBOL),size=3,color="black",fontface="italic",
                        box.padding=.4,max.overlaps=Inf,seed=42) +
        coord_cartesian(xlim=c(-xmax,xmax),ylim=c(0,ymax)) +
        labs(title=ttl,
             subtitle="● = Activated target (MoR>0)  ▼ = Repressed target (MoR<0)  Filled = significant",
             x="log2 Fold Change (apeglm)", y=expression(-log[10](p[adj]))) +
        theme_classic(base_size=11) +
        theme(plot.title=element_text(face="bold",size=11),legend.position="none")
      save_fig(p, file.path(tf_dir,sprintf("%s_%s_vs_%s_%s",tf,
               gsub("[^A-Za-z0-9_]","_",m$treat),m$ctrl,m$branch)),
               w=CFG$fig_w_full, h=CFG$fig_h_tall)
    }
  }
  message("TF target analysis complete.")
}

