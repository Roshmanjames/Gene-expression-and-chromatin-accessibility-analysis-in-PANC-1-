                length(overall_files), NCORES))
overall_long <- safe_bind(par_lapply(overall_files, read_overall)) %>%
  group_by(Sample) %>%
  summarise(across(names(subst_codes), mean, na.rm=TRUE)) %>%
  pivot_longer(-Sample, names_to="SubCode", values_to="Rate") %>%
  mutate(Substitution = subst_codes[SubCode])

p <- ggplot(overall_long, aes(x=Sample, y=Substitution, fill=Rate)) +
  geom_tile(color="white", linewidth=.4) +
