                                                 FUN.VALUE = character(1)))),
    OR_plot = pmin(OR, OR_cap),
    sig_lab = case_when(FDR < .001 ~ "***", FDR < .01 ~ "**", FDR < .05 ~ "*", TRUE ~ ""),
    tile_label = sprintf("OR %.2f\np %s%s",
                          OR,
                          ifelse(p_value < 1e-4, "<1e-4",
                                 formatC(p_value, format = "f", digits = 4)),
                          ifelse(sig_lab != "", paste0(" ", sig_lab), "")),
    reliable = n_set >= 5
  )

p_or <- ggplot(plot_df_or, aes(x = comp, y = group, fill = OR_plot)) +
  geom_tile(aes(alpha = reliable), color = "grey88", linewidth = .6) +
  geom_text(aes(label = ifelse(reliable, tile_label, "n < 5")),
            size = 2.4, lineheight = 1.2, color = "grey15") +
  scale_fill_gradient(low = "grey85", high = "purple4",
                      limits = c(0, OR_cap),
                      breaks = c(0, 1, 2, 3, 4),
                      labels = c("0", "1", "2", "3", paste0("≥", OR_cap)),
                      name = "Odds Ratio") +
  scale_alpha_manual(values = c("TRUE" = 1, "FALSE" = 0.4), guide = "none") +
  facet_grid(. ~ branch, scales = "free_x", space = "free_x") +
  labs(
    title    = "Gene Set Enrichment among THZ531-Downregulated Genes",
    subtitle = sprintf("Fisher one-sided | padj < %.2g & log2FC ≤ −%.1f | tiles: OR + raw p-value",
                       0.05, 1.0),
    x = NULL, y = NULL
  ) +
  theme_minimal(base_size = 11) +
  theme(
    panel.grid     = element_blank(),
    axis.text.x    = element_text(angle = 35, hjust = 1),
    strip.text     = element_text(face = "bold"),
    plot.title     = element_text(face = "bold", size = 12),
    plot.subtitle  = element_text(size = 9, color = "grey40")
  )

save_fig(p_or, file.path(OUT7F, "OR_heatmap_gene_sets"),
