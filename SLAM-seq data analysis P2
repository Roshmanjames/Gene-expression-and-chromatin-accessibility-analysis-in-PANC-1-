read_readpos <- function(f) {
  df <- read_tsv(f, comment="#", col_names=FALSE, show_col_types=FALSE)
  colnames(df) <- c("TC_fwd","TC_rev","TC_norm_fwd","TC_norm_rev","total_fwd","total_rev")
  df %>% mutate(Position = row_number(),
                Rate_fwd = ifelse(total_fwd>0, TC_fwd/total_fwd, NA),
                Rate_rev = ifelse(total_rev>0, TC_rev/total_rev, NA),
                Sample   = rename_sample(extract_sample(f)))
}

