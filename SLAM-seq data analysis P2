}
all_names <- Reduce(union, lapply(steady_list, names))

build_mat <- function(lst, nm) {
  mat <- matrix(0L, nrow=length(nm), ncol=length(lst),
                dimnames=list(nm, names(lst)))
  for (s in names(lst)) { v <- lst[[s]]; mat[names(v), s] <- as.integer(v) }
  as.data.frame(mat, check.names=FALSE)
}
