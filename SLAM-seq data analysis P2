# ── Parallel backend ──────────────────────────────────────────────────────────
# mclapply (fork-based) hangs silently inside RStudio / knitr notebook chunks
# on Linux. USE_PARALLEL = FALSE forces plain lapply which is reliable in all
# environments. Set to TRUE only when running as a plain Rscript outside RStudio.
USE_PARALLEL <- FALSE
NCORES       <- min(4L, max(1L, parallel::detectCores() - 1L))
IS_WINDOWS   <- .Platform$OS.type == "windows"

par_lapply <- function(X, FUN, ...) {
  if (!USE_PARALLEL || length(X) == 0) {
    lapply(X, FUN, ...)
  } else if (IS_WINDOWS) {
    cl <- parallel::makeCluster(NCORES)
    on.exit(parallel::stopCluster(cl), add = TRUE)
    parallel::parLapply(cl, X, FUN, ...)
  } else {
    parallel::mclapply(X, FUN, mc.cores = NCORES, ...)
  }
}

# ── Safe null-filtering bind_rows ─────────────────────────────────────────────
safe_bind <- function(lst) {
  lst <- lst[!vapply(lst, is.null, logical(1))]
  if (length(lst) == 0) return(tibble())
  bind_rows(lst)
}

# ── Figure saving: PNG + TIFF ─────────────────────────────────────────────────
save_fig <- function(p, base, w = CFG$fig_w_full, h = CFG$fig_h_std,
                     dpi = CFG$fig_dpi) {
  wi <- w / 2.54;  hi <- h / 2.54
  ggsave(paste0(base, ".png"),  p, width = wi, height = hi, dpi = dpi)
  ggsave(paste0(base, ".tiff"), p, width = wi, height = hi, dpi = dpi,
         device = "tiff", compression = "lzw")
  message("  Saved: ", basename(base))
}

# ── pheatmap: PNG + TIFF ──────────────────────────────────────────────────────
save_heatmap <- function(mat, base, w = CFG$fig_w_full, h = CFG$fig_h_tall, ...) {
  wi <- round(w / 2.54 * CFG$fig_dpi)
  hi <- round(h / 2.54 * CFG$fig_dpi)
  png( paste0(base, ".png"),  width = wi, height = hi, res = CFG$fig_dpi)
  pheatmap(mat, ...); dev.off()
  tiff(paste0(base, ".tiff"), width = wi, height = hi, res = CFG$fig_dpi,
       compression = "lzw")
  pheatmap(mat, ...); dev.off()
  message("  Saved: ", basename(base))
}

