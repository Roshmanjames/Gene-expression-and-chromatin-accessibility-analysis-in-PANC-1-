read_overall <- function(f) {
  df <- read_tsv(f, comment = "#", col_names = FALSE, show_col_types = FALSE)
  colnames(df) <- c("RefBase","A","a","C","c","G","g","T","t","N","n","extra")
  df %>% filter(RefBase %in% c("A","C","G","T")) %>%
    mutate(across(c(A,C,G,T,N), as.numeric),
           Total  = A+C+G+T+N,
           sub_AC = C/Total, sub_AG = G/Total, sub_AT = T/Total,
           sub_CA = A/Total, sub_CG = G/Total, sub_CT = T/Total,
           sub_GA = A/Total, sub_GC = C/Total, sub_GT = T/Total,
           sub_TA = A/Total, sub_TC = C/Total, sub_TG = G/Total,
           Sample = rename_sample(extract_sample(f)))
}

subst_codes  <- c(sub_AC="A>C",sub_AG="A>G",sub_AT="A>T",
                   sub_CA="C>A",sub_CG="C>G",sub_CT="C>T",
                   sub_GA="G>A",sub_GC="G>C",sub_GT="G>T",
                   sub_TA="T>A",sub_TC="T>C",sub_TG="T>G")

