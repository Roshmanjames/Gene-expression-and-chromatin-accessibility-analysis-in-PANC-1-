reduce_sets <- function(sets, mode=c("union","intersect")) {
  mode <- match.arg(mode)
  sets <- sets[vapply(sets, function(x) length(x)>0, logical(1))]
  if (length(sets)==0) return(character(0))
  if (length(sets)==1) return(unique(sets[[1]]))
  if (mode=="union") unique(unlist(sets)) else Reduce(intersect, lapply(sets,unique))
}

# ── Main GO analysis function ─────────────────────────────────────────────────
run_go_analysis <- function(branch_cfg) {
  tag      <- branch_cfg$tag
  tps      <- branch_cfg$timepoints
  go_root  <- mkd(OUT5, tag)
  venn_dir <- mkd(go_root, "Venn_diagrams")
  ovl_dir  <- mkd(go_root, "Overlap_pathways")

  store <- list(nascent_up=list(), nascent_down=list(),
                steady_up =list(), steady_down =list())

  # ── Per-timepoint GO ───────────────────────────────────────────────────────
  for (tp in tps) {
    message("  GO per timepoint: ", tag, " ", tp)
    tp_dir <- mkd(go_root, tp)
    cond   <- paste0(tag,"-",tp)
    f_nas  <- file.path(CFG$outdir,"nascent",tag,
                        sprintf("nascent_%s_DE_%s_vs_%s_apeglm.csv",tag,cond,branch_cfg$ref))
    f_sst  <- file.path(CFG$outdir,"steady", tag,
                        sprintf("steady_%s_DE_%s_vs_%s_apeglm.csv", tag,cond,branch_cfg$ref))

    nas_up   <- read_de_genes(f_nas,"up",   top_n=CFG$go_N_nascent)
    nas_down <- read_de_genes(f_nas,"down", top_n=CFG$go_N_nascent)
    sst_up   <- read_de_genes(f_sst,"up",   lfc_cut=CFG$lfc_cut_steady,padj_cut=CFG$padj_cut_steady)
    sst_down <- read_de_genes(f_sst,"down", lfc_cut=CFG$lfc_cut_steady,padj_cut=CFG$padj_cut_steady)

    store$nascent_up[[tp]]   <- nas_up
    store$nascent_down[[tp]] <- nas_down
    store$steady_up[[tp]]    <- sst_up
    store$steady_down[[tp]]  <- sst_down

    combos_tp <- list(
      list(g=nas_up,   lbl=paste0("Nascent_Up_",   tp), clo="#fee090", chi="#d73027"),
      list(g=nas_down, lbl=paste0("Nascent_Down_", tp), clo="#74add1", chi="#2166ac"),
      list(g=sst_up,   lbl=paste0("Steady_Up_",    tp), clo="#fdb863", chi="#e08214"),
      list(g=sst_down, lbl=paste0("Steady_Down_",  tp), clo="#7fbf7b", chi="#1b7837"))
    for (ci in combos_tp) {
      gr <- run_gost(ci$g, ci$lbl, tp_dir)
      go_dotplot(gr, ci$lbl, tp_dir, color_lo=ci$clo, color_hi=ci$chi)
    }
  }

  # ── Venn: per layer+direction across timepoints ───────────────────────────
  venn_specs <- list(
    list(key="nascent_up",   layer="Nascent",      dir="Upregulated",   colors=c("#FC8D62","#8DA0CB","#66C2A5")),
    list(key="nascent_down", layer="Nascent",      dir="Downregulated", colors=c("#FC8D62","#8DA0CB","#66C2A5")),
    list(key="steady_up",    layer="Steady-state", dir="Upregulated",   colors=c("#FC8D62","#8DA0CB","#66C2A5")),
    list(key="steady_down",  layer="Steady-state", dir="Downregulated", colors=c("#FC8D62","#8DA0CB","#66C2A5"))
  )
  for (vs in venn_specs) {
    gl <- store[[vs$key]]
    gl_ne <- gl[vapply(gl, function(x) length(x)>0, logical(1))]
    if (length(gl_ne) < 2) next
    plot_venn(gl_ne, labels=names(gl_ne),
              title=sprintf("%s — %s %s\nacross timepoints", tag, vs$layer, vs$dir),
              outfile=file.path(venn_dir, paste0(tag,"_",vs$key,"_Venn_timepoints")),
              fill_colors=vs$colors[seq_along(gl_ne)])
  }

  # ── Venn: Nascent vs Steady-state ─────────────────────────────────────────
  for (dir_lbl in c("up","down")) {
    dir_title <- ifelse(dir_lbl=="up","Upregulated","Downregulated")
    nas_union <- reduce_sets(store[[paste0("nascent_",dir_lbl)]], mode="union")
    sst_union <- reduce_sets(store[[paste0("steady_", dir_lbl)]], mode="union")
    if (length(nas_union)>0 && length(sst_union)>0) {
      plot_venn(list(Nascent=nas_union, `Steady-state`=sst_union),
                labels=c("Nascent","Steady-state"),
                title=sprintf("%s %s — Nascent vs Steady-state\n(union across all timepoints)",
                              tag, dir_title),
                outfile=file.path(venn_dir,paste0(tag,"_NasVsSST_",dir_lbl,"_UNION")),
                fill_colors=c("#E41A1C","#377EB8"))
    }
    nas_all <- reduce_sets(store[[paste0("nascent_",dir_lbl)]], mode="intersect")
    sst_all <- reduce_sets(store[[paste0("steady_", dir_lbl)]], mode="intersect")
    if (length(nas_all)>0 && length(sst_all)>0) {
      plot_venn(list(Nascent=nas_all, `Steady-state`=sst_all),
                labels=c("Nascent","Steady-state"),
                title=sprintf("%s %s — Nascent vs Steady-state\n(genes DE in ALL timepoints)",
                              tag, dir_title),
                outfile=file.path(venn_dir,paste0(tag,"_NasVsSST_",dir_lbl,"_ALLTP")),
                fill_colors=c("#4DAF4A","#984EA3"))
    }
  }

  # ── Pathway enrichment: 4 independent analyses on intersection gene sets ──
  message("  Pathway enrichment — 4 independent intersection analyses…")

  pathway_combos <- list(
    list(key="nascent_up",   label="Nascent — Upregulated in All Timepoints",
         sub="Nascent_Up_AllTimepoints",   clo="#fee090", chi="#d73027"),
    list(key="nascent_down", label="Nascent — Downregulated in All Timepoints",
         sub="Nascent_Down_AllTimepoints", clo="#74add1", chi="#2166ac"),
    list(key="steady_up",    label="Steady-state — Upregulated in All Timepoints",
         sub="Steady_Up_AllTimepoints",    clo="#fdb863", chi="#e08214"),
    list(key="steady_down",  label="Steady-state — Downregulated in All Timepoints",
         sub="Steady_Down_AllTimepoints",  clo="#7fbf7b", chi="#1b7837")
  )

  go_panels <- list()

  for (combo in pathway_combos) {
    cd        <- mkd(ovl_dir, combo$sub)
    genes_all <- reduce_sets(store[[combo$key]], mode="intersect")
    message(sprintf("    %s: %d intersection genes", combo$label, length(genes_all)))

    if (length(genes_all) == 0) {
      message("    → No genes shared across all timepoints — skipping")
      go_panels[[combo$sub]] <- NULL
      next
    }

    writeLines(sort(unique(genes_all)), file.path(cd, paste0(combo$sub,"_genes.txt")))
    g_res <- run_gost(genes_all, combo$sub, cd)

    if (is.null(g_res) || is.null(g_res$result) || nrow(g_res$result)==0) {
      message("    → No GO:BP hits")
      go_panels[[combo$sub]] <- NULL
      next
    }

    df_go <- g_res$result %>% arrange(p_value) %>% slice_head(n=10) %>%
      mutate(score      = -log10(p_value),
             gene_ratio = intersection_size / query_size,
             term_wrap  = str_wrap(term_name, width=38),
             term_wrap  = factor(term_wrap, levels=rev(unique(term_wrap))))

    p_ind <- ggplot(df_go, aes(x=score, y=term_wrap, size=gene_ratio, color=score)) +
      geom_point() +
      scale_color_gradient(low=combo$clo, high=combo$chi, name="-log10\n(FDR)") +
      scale_size_continuous(name="Gene\nRatio", range=c(2,8)) +
      labs(title    = combo$label,
           subtitle = sprintf("Top %d GO:BP | n = %d genes", nrow(df_go), length(genes_all)),
           x = "-log10(Adjusted P-value)", y = NULL) +
      theme_classic(base_size=10) +
      theme(plot.title    = element_text(face="bold", size=9),
            plot.subtitle = element_text(size=8, color="grey40"),
            axis.text.y   = element_text(size=8),
            legend.title  = element_text(size=7),
            legend.text   = element_text(size=7))

    save_fig(p_ind, file.path(cd, paste0(combo$sub,"_GO_top10")),
             w=CFG$fig_w_full, h=CFG$fig_h_tall)
    go_panels[[combo$sub]] <- p_ind
  }

  valid_panels <- go_panels[!vapply(go_panels, is.null, logical(1))]
  if (length(valid_panels) >= 2) {
    p_comb <- wrap_plots(valid_panels, ncol=2) +
      plot_annotation(
        title    = "GO:BP Pathway Enrichment — Genes DE in All Timepoints",
        subtitle = sprintf("Intersection genes (2h ∩ 4h ∩ 6h) | 4 independent analyses | %s vs DMSO", tag),
        theme    = theme(plot.title    = element_text(face="bold", size=13),
                         plot.subtitle = element_text(size=9, color="grey40")))
    save_fig(p_comb, file.path(ovl_dir, paste0(tag,"_GO_combined_4panel")),
             w=CFG$fig_w_full * 1.3, h=CFG$fig_h_tall * 2)
    message("  Saved combined 4-panel GO figure")
  }

  message("GO analysis complete for ", tag)
}

