parse_sample <- function(x) {
  rep <- str_match(x,"(?i)rep\\s*([0-9]+)")[,2]
  tx  <- ifelse(str_detect(x,"DMSO"),"DMSO",ifelse(str_detect(x,"THZ531"),"THZ531","OTHER"))
  tp  <- str_match(x,"([0-9]+)\\s*h")[,2]
  tp  <- ifelse(is.na(tp),"0h",paste0(tp,"h"))
